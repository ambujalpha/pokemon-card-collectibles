# ---- Supabase Postgres ----
# Pooled URL used by Next.js serverless. Includes pgbouncer flag.
DATABASE_URL="postgresql://postgres:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct URL used by Prisma migrations only.
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ---- Upstash Redis ----
# ioredis-style rediss:// URL from the Upstash console ("Redis (TCP)" option).
REDIS_URL="rediss://default:[token]@[region].upstash.io:6379"

# ---- JWT ----
# Generate with:  openssl rand -base64 32
JWT_SECRET="replace-me-with-32-bytes-of-entropy"

# ---- Pokemon TCG API (Phase 3) ----
# https://dev.pokemontcg.io  —  free key, 1000 req/day
POKEMON_TCG_API_KEY=""

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
