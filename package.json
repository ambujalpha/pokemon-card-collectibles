{
  "name": "pullvault",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:ws": "pnpm --filter ws dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter web test",
    "prisma:generate": "pnpm --filter web exec prisma generate",
    "prisma:migrate": "pnpm --filter web exec prisma migrate dev",
    "prisma:studio": "pnpm --filter web exec prisma studio",
    "seed": "pnpm --filter web seed",
    "fetch:cards": "pnpm --filter web fetch:cards",
    "calibrate:rarity": "pnpm --filter web calibrate:rarity",
    "reset:drops": "pnpm --filter web reset:drops"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "sharp",
      "esbuild"
    ]
  }
}
