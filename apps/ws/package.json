{
  "name": "ws",
  "version": "0.0.1",
  "private": true,
  "description": "Socket.io server for PullVault. Phase 1: live inventory counter on drop pages. Phase 6 adds auction rooms + Redis adapter for multi-instance.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
