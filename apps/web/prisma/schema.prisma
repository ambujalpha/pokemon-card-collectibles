// PullVault — Prisma schema
// See docs/architecture/HLD.md §6 for the data model and its invariants.
// Phase 0: users + ledger. Phase 1: cards, drops, user_packs, pack_cards.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  balance      Decimal  @default(0) @db.Decimal(18, 4)
  balanceHeld  Decimal  @default(0) @map("balance_held") @db.Decimal(18, 4)
  isAdmin      Boolean  @default(false) @map("is_admin")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  ledger       Ledger[]
  createdDrops Drop[]     @relation("DropCreator")
  packs        UserPack[]
  cards        UserCard[]
  listings     Listing[]  @relation("ListingSeller")
  purchases    Listing[]  @relation("ListingBuyer")
  auctionsSold Auction[]  @relation("AuctionSeller")
  auctionsWon  Auction[]  @relation("AuctionWinner")
  bids         Bid[]

  @@map("users")
}

// ─── Ledger (audit trail for every balance movement) ────────────────────────

model Ledger {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  delta        Decimal      @db.Decimal(18, 4)
  reason       LedgerReason
  refType      String       @map("ref_type")
  refId        String?      @map("ref_id") @db.Uuid
  balanceAfter Decimal      @map("balance_after") @db.Decimal(18, 4)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, createdAt])
  @@index([reason, createdAt])
  @@map("ledger")
}

enum LedgerReason {
  FUND_DEPOSIT
  PACK_PURCHASE
  TRADE_BUY
  TRADE_SELL
  TRADE_FEE
  BID_HOLD
  BID_RELEASE
  AUCTION_WIN
  AUCTION_SELL
  AUCTION_FEE

  @@map("ledger_reason_enum")
}

// ─── Cards ──────────────────────────────────────────────────────────────────

model Card {
  id           String    @id @default(uuid()) @db.Uuid
  pokemontcgId String    @unique @map("pokemontcg_id")
  name         String
  setCode      String    @map("set_code")
  number       String
  rarityBucket Rarity    @map("rarity_bucket")
  imageUrl     String    @map("image_url")
  basePrice    Decimal   @map("base_price") @db.Decimal(18, 4)
  lastPricedAt DateTime? @map("last_priced_at") @db.Timestamptz
  staleSince   DateTime? @map("stale_since") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  packCards      PackCard[]
  priceSnapshots PriceSnapshot[]
  userCards      UserCard[]

  @@index([rarityBucket])
  @@map("cards")
}

// ─── Price snapshots (Phase 3 history — one row per card per refresh) ───────

model PriceSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  cardId      String   @map("card_id") @db.Uuid
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  price       Decimal  @db.Decimal(18, 4)
  refreshedAt DateTime @default(now()) @map("refreshed_at") @db.Timestamptz

  @@index([cardId, refreshedAt(sort: Desc)])
  @@map("price_snapshots")
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY

  @@map("rarity_enum")
}

// ─── Drops ──────────────────────────────────────────────────────────────────

model Drop {
  id             String     @id @default(uuid()) @db.Uuid
  packTier       PackTier   @map("pack_tier")
  totalInventory Int        @map("total_inventory")
  remaining      Int
  startsAt       DateTime   @map("starts_at") @db.Timestamptz
  endsAt         DateTime   @map("ends_at") @db.Timestamptz
  status         DropStatus @default(SCHEDULED)
  createdBy      String     @map("created_by") @db.Uuid
  creator        User       @relation("DropCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz

  packs UserPack[]

  @@index([status, startsAt])
  @@map("drops")
}

enum PackTier {
  STARTER
  PREMIUM
  ULTRA

  @@map("pack_tier_enum")
}

enum DropStatus {
  SCHEDULED
  LIVE
  ENDED
  SOLD_OUT

  @@map("drop_status_enum")
}

// ─── User-owned packs + their contents ──────────────────────────────────────

model UserPack {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  user            User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  dropId          String             @map("drop_id") @db.Uuid
  drop            Drop               @relation(fields: [dropId], references: [id], onDelete: Restrict)
  purchasedAt     DateTime           @default(now()) @map("purchased_at") @db.Timestamptz
  isRevealed      Boolean            @default(false) @map("is_revealed")
  weightVersionId String?            @map("weight_version_id") @db.Uuid
  weightVersion   PackWeightVersion? @relation(fields: [weightVersionId], references: [id], onDelete: Restrict)

  cards PackCard[]

  @@index([userId, isRevealed])
  @@index([userId, dropId])
  @@map("user_packs")
}

// ─── Phase 8: per-tier rarity weight versions (economics solver output) ─────

model PackWeightVersion {
  id                String   @id @default(uuid()) @db.Uuid
  tier              PackTier
  weightsJson       Json     @map("weights_json")
  solvedForPricesAt DateTime @map("solved_for_prices_at") @db.Timestamptz
  evPerPackUsd      Decimal  @map("ev_per_pack_usd") @db.Decimal(18, 4)
  targetMargin      Decimal  @map("target_margin") @db.Decimal(6, 4)
  realisedMargin    Decimal  @map("realised_margin") @db.Decimal(6, 4)
  constraintBinding String?  @map("constraint_binding")
  isActive          Boolean  @default(false) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  userPacks UserPack[]

  @@index([tier, isActive])
  @@map("pack_weight_versions")
}

model PackCard {
  id             String   @id @default(uuid()) @db.Uuid
  userPackId     String   @map("user_pack_id") @db.Uuid
  userPack       UserPack @relation(fields: [userPackId], references: [id], onDelete: Cascade)
  cardId         String   @map("card_id") @db.Uuid
  card           Card     @relation(fields: [cardId], references: [id], onDelete: Restrict)
  pricedCaptured Decimal  @map("priced_captured") @db.Decimal(18, 4)
  position       Int

  userCard UserCard?

  @@index([userPackId])
  @@map("pack_cards")
}

// ─── User-owned cards (Phase 4+5) ───────────────────────────────────────────
//
// Created on pack reveal (one row per pack_card). Ownership moves via
// marketplace purchase — user_cards.userId flips and status becomes HELD on
// the new owner (seller's row is replaced — we reuse the same id by UPDATE,
// preserving provenance via packCardId → user_packs).
//
// Invariants:
//   - Exactly one user_cards row per pack_cards row (1:1, enforced by unique).
//   - A card is LISTED iff there is an ACTIVE listing with this user_card_id.
//   - acquiredPrice is what the CURRENT owner paid: allocated pack cost for
//     pulls, listing price for marketplace purchases. P&L is always
//     (card.basePrice - user_card.acquiredPrice).

model UserCard {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  packCardId    String         @unique @map("pack_card_id") @db.Uuid
  packCard      PackCard       @relation(fields: [packCardId], references: [id], onDelete: Cascade)
  cardId        String         @map("card_id") @db.Uuid
  card          Card           @relation(fields: [cardId], references: [id], onDelete: Restrict)
  acquiredAt    DateTime       @default(now()) @map("acquired_at") @db.Timestamptz
  acquiredPrice Decimal        @map("acquired_price") @db.Decimal(18, 4)
  status        UserCardStatus @default(HELD)

  listings Listing[]
  auctions Auction[]

  @@index([userId, status])
  @@index([cardId])
  @@map("user_cards")
}

enum UserCardStatus {
  HELD
  LISTED
  AUCTION
  SOLD

  @@map("user_card_status_enum")
}

// ─── Marketplace listings (Phase 5) ─────────────────────────────────────────

model Listing {
  id          String        @id @default(uuid()) @db.Uuid
  sellerId    String        @map("seller_id") @db.Uuid
  seller      User          @relation("ListingSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  userCardId  String        @map("user_card_id") @db.Uuid
  userCard    UserCard      @relation(fields: [userCardId], references: [id], onDelete: Restrict)
  priceAsk    Decimal       @map("price_ask") @db.Decimal(18, 4)
  status      ListingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  soldAt      DateTime?     @map("sold_at") @db.Timestamptz
  buyerId     String?       @map("buyer_id") @db.Uuid
  buyer       User?         @relation("ListingBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  cancelledAt DateTime?     @map("cancelled_at") @db.Timestamptz

  @@index([status, createdAt(sort: Desc)])
  @@index([sellerId, status])
  @@map("listings")
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED

  @@map("listing_status_enum")
}

// ─── Auctions (Phase 6) ─────────────────────────────────────────────────────
//
// Auction lifecycle: LIVE → CLOSED (settled with or without a winner) or
// CANCELLED (seller cancels before any bid). `closesAt` may extend during
// LIVE via anti-snipe: a bid inside the final 30s pushes closesAt forward by
// +30s, capped at 20 extensions total (see PARAMETERS.md).
//
// Funds: buyer balance_held covers the current high bid. On place, the bid
// amount is moved from balance → balance_held with BID_HOLD ledger entry.
// On outbid, the loser gets BID_RELEASE back to balance. On close with a
// winner, seller gets AUCTION_SELL (+95% of final bid) + AUCTION_FEE (−5%).
// Winner's balance_held is debited directly on settlement (no second move).

model Auction {
  id              String        @id @default(uuid()) @db.Uuid
  sellerId        String        @map("seller_id") @db.Uuid
  seller          User          @relation("AuctionSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  userCardId      String        @unique @map("user_card_id") @db.Uuid
  userCard        UserCard      @relation(fields: [userCardId], references: [id], onDelete: Restrict)
  startingBid     Decimal       @map("starting_bid") @db.Decimal(18, 4)
  currentBid      Decimal?      @map("current_bid") @db.Decimal(18, 4)
  currentBidderId String?       @map("current_bidder_id") @db.Uuid
  startsAt        DateTime      @default(now()) @map("starts_at") @db.Timestamptz
  closesAt        DateTime      @map("closes_at") @db.Timestamptz
  extensions      Int           @default(0)
  status          AuctionStatus @default(LIVE)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  closedAt        DateTime?     @map("closed_at") @db.Timestamptz
  winnerId        String?       @map("winner_id") @db.Uuid
  winner          User?         @relation("AuctionWinner", fields: [winnerId], references: [id], onDelete: Restrict)

  bids Bid[]

  @@index([status, closesAt])
  @@index([sellerId, status])
  @@map("auctions")
}

enum AuctionStatus {
  LIVE
  CLOSED
  CANCELLED

  @@map("auction_status_enum")
}

// Bid is an append-only audit log. The *current* high bid is denormalised
// onto auctions.currentBid/currentBidderId for fast read; bids table is the
// full history (used for the /auctions/:id detail timeline).
model Bid {
  id        String   @id @default(uuid()) @db.Uuid
  auctionId String   @map("auction_id") @db.Uuid
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderId  String   @map("bidder_id") @db.Uuid
  bidder    User     @relation(fields: [bidderId], references: [id], onDelete: Restrict)
  amount    Decimal  @db.Decimal(18, 4)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([auctionId, createdAt(sort: Desc)])
  @@index([bidderId, createdAt(sort: Desc)])
  @@map("bids")
}
